# Anthropic API key (required)
ANTHROPIC_API_KEY=sk-ant-...

# Model overrides (optional)
ROSETTA_LEAD_MODEL=claude-opus-4-6
ROSETTA_WORKER_MODEL=claude-sonnet-4-6

# SSOT directory (optional, defaults to ./ssot)
ROSETTA_SSOT_DIR=./ssot

# Docker compute image (optional)
ROSETTA_DOCKER_IMAGE=rosetta-compute:latest
